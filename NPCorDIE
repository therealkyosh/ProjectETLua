local function UpdateLogic()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Player and v.Character then
            local teamName = v.Team and v.Team.Name or "None"
            local isCrim = string.find(string.lower(teamName), "crim")
            local isSheriff = string.find(string.lower(teamName), "sheriff")
            
            local tag = v.Character:FindFirstChild("ET_TeamTag")
            if _G.TeamDisplay then
                if not tag and v.Character:FindFirstChild("Head") then
                    tag = Instance.new("BillboardGui")
                    tag.Name = "ET_TeamTag"
                    tag.Size = UDim2.new(0, 100, 0, 50)
                    tag.Adornee = v.Character.Head
                    tag.AlwaysOnTop = true
                    tag.ExtentsOffset = Vector3.new(0, 2, 0)
                    local txt = Instance.new("TextLabel", tag)
                    txt.BackgroundTransparency = 1
                    txt.Size = UDim2.new(1, 0, 1, 0)
                    txt.Font = Enum.Font.GothamBold
                    txt.TextSize = 14
                    txt.Text = "[Player]"
                    txt.TextColor3 = v.TeamColor and v.TeamColor.Color or Color3.fromRGB(255, 255, 255)
                    txt.TextStrokeTransparency = 0.5
                    tag.Parent = v.Character
                end
            elseif tag then tag:Destroy() end

            local highlight = v.Character:FindFirstChild("ET_Highlight")
            if _G.CrimESP or _G.SheriffESP or _G.UniESP then
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "ET_Highlight"
                    highlight.Parent = v.Character
                end
                highlight.Enabled = false
                if _G.CrimESP and isCrim then
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    highlight.Enabled = true
                elseif _G.SheriffESP and isSheriff then
                    highlight.FillColor = Color3.fromRGB(0, 0, 255)
                    highlight.Enabled = true
                elseif _G.UniESP then
                    highlight.FillColor = v.TeamColor and v.TeamColor.Color or Color3.fromRGB(255, 255, 255)
                    highlight.Enabled = true
                end
            elseif highlight then highlight:Destroy() end

            local finder = v.Character:FindFirstChild("ET_Finder")
            if _G.CrimFinder and isCrim then
                if not finder and v.Character:FindFirstChild("Head") then
                    finder = Instance.new("BillboardGui")
                    finder.Name = "ET_Finder"
                    finder.Size = UDim2.new(0, 50, 0, 50)
                    finder.Adornee = v.Character.Head
                    finder.AlwaysOnTop = true
                    finder.ExtentsOffset = Vector3.new(0, 3, 0)
                    local txt = Instance.new("TextLabel", finder)
                    txt.BackgroundTransparency = 1
                    txt.Size = UDim2.new(1, 0, 1, 0)
                    txt.Text = "⚔️"
                    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
                    txt.TextSize = 25
                    finder.Parent = v.Character
                end
            elseif finder then finder:Destroy() end

            local hrp = v.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                if _G.HitboxExp then
                    hrp.Size = Vector3.new(_G.HitboxMult, _G.HitboxMult, _G.HitboxMult)
                    hrp.Transparency = 1
                    hrp.CanCollide = false
                else
                    hrp.Size = Vector3.new(2, 2, 1)
                    hrp.Transparency = 1
                end
            end
        end
    end
end

local LastTime = tick()
local FrameCount = 0

RunService.Heartbeat:Connect(function()
    if not Running then return end
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
		if _G.WSEnabled then
			Player.Character.Humanoid.WalkSpeed = _G.WS
		end
		Player.Character.Humanoid.JumpPower = _G.JP
		if _G.Noclip then
			for _, v in pairs(Player.Character:GetDescendants()) do
				if v:IsA("BasePart") then v.CanCollide = false end
			end
		end
	end
    
    UpdateLogic()

    if _G.RainbowUI then
        local hue = tick() % 5 / 5
        local color = Color3.fromHSV(hue, 1, 1)
        MainStroke.Color = color
        TStroke.Color = color
    else
        MainStroke.Color = Color3.fromRGB(255, 255, 255)
        TStroke.Color = Color3.fromRGB(255, 255, 255)
    end

    FrameCount = FrameCount + 1
    if tick() - LastTime >= 1 then
        FPSLabel.Text = "FPS: " .. FrameCount
        PlayerCountLabel.Text = "Players: " .. #Players:GetPlayers() .. " / " .. Players.MaxPlayers
        FrameCount = 0
        LastTime = tick()
    end
end)

